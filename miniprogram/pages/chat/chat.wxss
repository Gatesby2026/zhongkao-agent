/* pages/chat/chat.wxss
 * 群聊 UI 样式 - 仿微信群聊体验
 */

.page {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  background: #ededed;
}

/* ============== 顶部提示条 ============== */
.banner {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  background: rgba(59, 130, 246, 0.08);
  color: #1d4ed8;
  font-size: 22rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* ============== 滚动消息区 ============== */
.scroll-area {
  flex: 1;
  min-height: 0;
}

.msg-list {
  padding: 20rpx 0;
}

.bottom-spacer {
  height: 40rpx;
}

/* ============== 系统消息 ============== */
.sys-msg {
  display: flex;
  justify-content: center;
  margin: 16rpx 80rpx;
}

.sys-msg text {
  padding: 6rpx 16rpx;
  background: rgba(0, 0, 0, 0.18);
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 6rpx;
  max-width: 80%;
  text-align: center;
}

.time-divider {
  text-align: center;
  margin: 30rpx 0 14rpx;
}

.time-divider text {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(0, 0, 0, 0.18);
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 6rpx;
}

/* ============== 消息行 ============== */
.msg-row {
  display: flex;
  padding: 12rpx 24rpx;
  align-items: flex-start;
}

.msg-row-left {
  justify-content: flex-start;
}

.msg-row-right {
  justify-content: flex-end;
}

/* ============== 头像 ============== */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-char {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 500;
}

.msg-row-left .avatar {
  margin-right: 16rpx;
}

.msg-row-right .avatar {
  margin-left: 16rpx;
}

/* ============== 消息体 ============== */
.msg-body {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.msg-row-right .msg-body {
  align-items: flex-end;
}

/* 老师名 */
.msg-name {
  font-size: 22rpx;
  color: #888888;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.name-text {
  margin-right: 8rpx;
}

.role-tag {
  display: inline-block;
  padding: 2rpx 8rpx;
  background: rgba(59, 130, 246, 0.12);
  color: #1d4ed8;
  font-size: 20rpx;
  border-radius: 4rpx;
}

/* ============== 文字气泡 ============== */
.bubble {
  padding: 18rpx 22rpx;
  border-radius: 8rpx;
  position: relative;
  word-break: break-all;
  line-height: 1.5;
}

.bubble-left {
  background: #ffffff;
  color: #1a1a1a;
  border-top-left-radius: 4rpx;
}

.bubble-right {
  background: #95ec69;
  color: #1a1a1a;
  border-top-right-radius: 4rpx;
}

.bubble-text {
  font-size: 30rpx;
  white-space: pre-wrap;
}

/* ============== 图片消息 ============== */
.bubble-image {
  padding: 12rpx;
}

.image-placeholder {
  width: 320rpx;
  height: 240rpx;
  background: #f5f5f5;
  border: 2rpx dashed #cccccc;
  border-radius: 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.image-icon {
  font-size: 56rpx;
}

.image-desc {
  color: #888888;
  font-size: 24rpx;
}

/* ============== 卡片消息 ============== */
.card {
  width: 480rpx;
  background: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  padding: 20rpx 24rpx 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-items {
  padding: 8rpx 0;
}

.card-item {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  font-size: 26rpx;
}

.card-icon {
  width: 44rpx;
  font-size: 32rpx;
  flex-shrink: 0;
}

.card-label {
  flex: 1;
  color: #1a1a1a;
}

.card-value {
  color: #6b7280;
  font-size: 24rpx;
}

.card-footer {
  padding: 14rpx 24rpx;
  background: #fafafa;
  color: #3b82f6;
  font-size: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: right;
}

/* ============== 底部输入栏 ============== */
.input-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #f7f7f7;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.input-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: #4b5563;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  background: #ffffff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.send-btn {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  background: #07c160;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 28rpx;
}
