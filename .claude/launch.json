{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 5173
    },
    {
      "name": "zhiyuan-map",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8778", "--directory", "out"],
      "port": 8778
    },
    {
      "name": "zhiyuan-served",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "--app-dir", "server", "main:app", "--host", "127.0.0.1", "--port", "8200"],
      "port": 8200
    }
  ]
}
